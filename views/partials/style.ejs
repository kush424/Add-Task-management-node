<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #fafafa;
    --card: #ffffff;
    --text: #292524;
    --muted: #78716c;
    --border: #e7e5e4;
    --primary: #f59e0b;
    --primary-dark: #d97706;
    --primary-bg: #fffbeb;
    --danger: #dc2626;
    --danger-bg: #fef2f2;
    --success: #16a34a;
    --radius: 10px;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
  }
  h2, h3, .heading-font { font-family: 'Nunito', sans-serif; }
  a { color: inherit; }
  .container { max-width: 560px; margin: 32px auto; padding: 0 16px; }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 12px;
  }
  h2 { font-size: 19px; font-weight: 700; margin: 0 0 16px; display: flex; align-items: center; gap: 8px; }
  h3 { font-size: 14px; font-weight: 700; color: var(--muted); margin: 20px 0 10px; text-transform: uppercase; letter-spacing: 0.03em; }
  label { font-size: 13px; color: var(--muted); display: block; margin-bottom: 4px; font-weight: 500; }
  input, select, textarea {
    width: 100%;
    padding: 10px 12px;
    margin-bottom: 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
    background: #fff;
  }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-bg); }
  button, .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    border: none;
    border-radius: 8px;
    background: var(--primary);
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    text-decoration: none;
  }
  button:hover, .btn:hover { background: var(--primary-dark); }
  .btn-ghost { background: none; color: var(--muted); padding: 6px 10px; font-weight: 500; }
  .btn-ghost:hover { background: #f5f5f4; color: var(--text); }
  .btn-danger { background: none; color: var(--danger); padding: 6px 10px; font-weight: 500; }
  .btn-danger:hover { background: var(--danger-bg); }
  .btn-block { width: 100%; justify-content: center; }
  .error-box {
    display: flex; align-items: center; gap: 8px;
    background: var(--danger-bg); color: #b91c1c; padding: 10px 14px;
    border-radius: 8px; font-size: 14px; margin-bottom: 14px;
  }
  .badge {
    display: inline-flex; align-items: center;
    padding: 2px 10px; border-radius: 999px;
    font-size: 12px; font-weight: 600;
  }
  .badge-pending { background: #fef3c7; color: #92400e; }
  .badge-in-progress { background: #dbeafe; color: #1e40af; }
  .badge-completed { background: #dcfce7; color: #166534; }
  .badge-role { background: var(--primary-bg); color: var(--primary-dark); }
  .row { display: flex; justify-content: space-between; align-items: center; }
  .muted { color: var(--muted); font-size: 13px; }
  .empty-state { text-align: center; padding: 40px 20px; color: var(--muted); }
  .icon { width: 16px; height: 16px; stroke-width: 2; flex-shrink: 0; vertical-align: -3px; }
  .icon-lg { width: 28px; height: 28px; stroke-width: 1.8; }
</style>
