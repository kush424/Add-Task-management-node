<style>
  .navbar { display:flex; justify-content:space-between; align-items:center; padding:12px 24px; background:#fff; border-bottom:1px solid #e7e5e4; font-family:'Inter',sans-serif; position:relative; }
  .nav-links { display:flex; gap:2px; align-items:center; }
  .nav-link { display:flex; align-items:center; gap:6px; color:#57534e; text-decoration:none; font-size:14px; font-weight:500; padding:8px 12px; border-radius:7px; }
  .nav-link:hover { background:#fafaf9; }
  details.dropdown { position:relative; }
  details.dropdown summary { list-style:none; cursor:pointer; }
  details.dropdown summary::-webkit-details-marker { display:none; }
  details.dropdown[open] summary { background:#fafaf9; border-radius:7px; }
  .dropdown-menu { position:absolute; right:0; top:calc(100% + 6px); background:#fff; border:1px solid #e7e5e4; border-radius:9px; box-shadow:0 4px 14px rgba(0,0,0,0.08); min-width:170px; overflow:hidden; z-index:10; }
  .dropdown-menu a { display:flex; align-items:center; gap:8px; padding:9px 14px; font-size:14px; color:#44403c; text-decoration:none; }
  .dropdown-menu a:hover { background:#fafaf9; }
  .user-chip { display:flex; align-items:center; gap:6px; font-size:12px; font-weight:600; color:#d97706; background:#fffbeb; padding:5px 10px; border-radius:999px; margin-left:6px; }
</style>

<nav class="navbar">
  <a href="/tasks" class="nav-link" style="font-weight:700; color:#1c1917; font-size:15px;">
    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
    TaskApp
  </a>

  <% if (user) { %>
  <div class="nav-links">
    <a href="/tasks" class="nav-link">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      My Tasks
    </a>

    <% if (user.role === 'admin') { %>
    <details class="dropdown">
      <summary class="nav-link">
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Admin
        <svg class="icon" style="width:12px;height:12px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="dropdown-menu">
        <a href="/tasks/new">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Assign Task
        </a>
        <a href="/categories/manage">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41L13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Categories
        </a>
        <a href="/admin/employees">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Employees
        </a>
      </div>
    </details>
    <% } %>

    <a href="/logout" class="nav-link" style="color:#dc2626;">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    </a>

    <span class="user-chip"><%= user.username %></span>
  </div>
  <% } %>
</nav>
