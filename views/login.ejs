<!DOCTYPE html>
<html>
<head>
  <title>Login · TaskApp</title>
  <%- include('partials/style') %>
</head>
<body>
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;">
    <div class="card" style="width:340px;">
      <div style="text-align:center;margin-bottom:20px;">
        <div style="width:52px;height:52px;background:var(--primary-bg);border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
          <svg class="icon-lg" style="color:var(--primary-dark);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h2 style="justify-content:center;">Sign in to TaskApp</h2>
        <p class="muted" style="margin:0;">One login for both admins & employees</p>
      </div>

      <% if (error) { %>
        <div class="error-box">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <label>Username</label>
        <input name="username" placeholder="Enter your username" required autofocus/>
        <label>Password</label>
        <input name="password" type="password" placeholder="Enter your password" required/>
        <button type="submit" class="btn-block" style="margin-top:6px;">Login</button>
      </form>

      <p class="muted" style="text-align:center;margin-top:16px;margin-bottom:0;">
        Don't have an account? Ask your admin to create one for you.
      </p>
    </div>
  </div>
</body>
</html>
