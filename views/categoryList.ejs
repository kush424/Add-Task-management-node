<!DOCTYPE html>
<html>
<head>
  <title>Categories · TaskApp</title>
  <%- include('partials/style') %>
</head>
<body>
  <%- include('navbar') %>
  <div class="container">
    <h2>
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41L13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      Manage Categories
    </h2>

    <div class="card">
      <form method="POST" action="/categories" style="display:flex;gap:8px;margin:0;">
        <input name="name" placeholder="New category name" required style="margin:0;"/>
        <button type="submit">Add</button>
      </form>
    </div>

    <% if (categories.length === 0) { %>
      <div class="card empty-state">No categories yet. Add one above.</div>
    <% } %>

    <% categories.forEach(cat => { %>
      <div class="card row">
        <form method="POST" action="/categories/<%= cat._id %>" style="display:flex;gap:8px;flex:1;margin:0;">
          <input name="name" value="<%= cat.name %>" style="margin:0;"/>
          <button type="submit">Save</button>
        </form>
        <form method="POST" action="/categories/<%= cat._id %>/delete" style="margin:0 0 0 8px;">
          <button type="submit" class="btn-danger">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
          </button>
        </form>
      </div>
    <% }) %>
  </div>
</body>
</html>
