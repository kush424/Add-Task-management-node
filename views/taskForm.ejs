<!DOCTYPE html>
<html>
<head>
  <title><%= task ? 'Edit' : 'New' %> Task · TaskApp</title>
  <%- include('partials/style') %>
</head>
<body>
  <%- include('navbar') %>
  <div class="container" style="max-width:420px;">

    <% if (currentUser.role === 'admin') { %>
      <div class="card">
        <h2>
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <%= task ? 'Edit Task' : 'Assign New Task' %>
        </h2>
        <form method="POST" action="<%= task ? '/tasks/' + task._id : '/tasks' %>">

          <label>Assign To</label>
          <select name="assignedUser">
            <% users.forEach(u => { %>
              <option value="<%= u._id %>" <%= task && String(task.user) === String(u._id) ? 'selected' : '' %>>
                <%= u.username %> (<%= u.role %>)
              </option>
            <% }) %>
          </select>

          <label>Title</label>
          <input name="title" placeholder="Task title" value="<%= task ? task.title : '' %>" required/>

          <label>Description</label>
          <textarea name="description" placeholder="Task description" rows="3"><%= task ? task.description : '' %></textarea>

          <label>Status</label>
          <select name="status">
            <% ['pending','in-progress','completed'].forEach(s => { %>
              <option value="<%= s %>" <%= task && task.status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>

          <label>Category</label>
          <select name="category">
            <option value="">-- No Category --</option>
            <% categories.forEach(c => { %>
              <option value="<%= c._id %>" <%= task && task.category && String(task.category) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>

          <button type="submit" class="btn-block">Save Task</button>
        </form>
      </div>

    <% } else { %>
      <div class="card">
        <h2>
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Update Status
        </h2>
        <p style="font-weight:600;margin:0 0 4px;"><%= task.title %></p>
        <p class="muted" style="margin:0 0 16px;"><%= task.description %></p>

        <form method="POST" action="/tasks/<%= task._id %>">
          <label>Status</label>
          <select name="status">
            <% ['pending','in-progress','completed'].forEach(s => { %>
              <option value="<%= s %>" <%= task.status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn-block">Update Status</button>
        </form>
      </div>
    <% } %>

  </div>
</body>
</html>
