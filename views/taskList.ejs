<!DOCTYPE html>
<html>
<head>
  <title>Tasks · TaskApp</title>
  <%- include('partials/style') %>
</head>
<body>
  <%- include('navbar') %>
  <div class="container">
    <h2>
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      <%= user.role === 'admin' ? 'All Tasks' : 'My Tasks' %>
    </h2>

    <% if (tasks.length === 0) { %>
      <div class="card empty-state">
        <svg class="icon-lg" style="margin:0 auto 10px;display:block;color:#d6d3d1;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
        <p style="margin:0;"><%= user.role === 'admin' ? 'No tasks created yet. Assign one!' : 'No tasks assigned to you yet.' %></p>
      </div>
    <% } %>

    <% tasks.forEach(task => { %>
      <%- include('taskItem', { task, user }) %>
    <% }) %>
  </div>
</body>
</html>
