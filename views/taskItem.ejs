<div class="card row">
  <div>
    <div style="font-weight:600;font-size:15px;margin-bottom:4px;display:flex;align-items:center;gap:8px;">
      <%= task.title %>
      <span class="badge badge-<%= task.status %>"><%= task.status %></span>
    </div>
    <div class="muted" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
      <%= task.description %>
      <% if (task.category) { %>
        <span style="display:inline-flex;align-items:center;gap:3px;">
          <svg class="icon" style="width:13px;height:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41L13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          <%= task.category.name %>
        </span>
      <% } %>
      <% if (user.role === 'admin') { %>
        <span style="display:inline-flex;align-items:center;gap:3px;">
          <svg class="icon" style="width:13px;height:13px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <%= task.user.username %>
        </span>
      <% } %>
    </div>
  </div>
  <div style="display:flex;gap:4px;">
    <a href="/tasks/<%= task._id %>/edit" class="btn-ghost">
      <% if (user.role === 'admin') { %>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Edit
      <% } else { %>
        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Status
      <% } %>
    </a>
    <% if (user.role === 'admin') { %>
      <form method="POST" action="/tasks/<%= task._id %>/delete" style="margin:0;">
        <button type="submit" class="btn-danger">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
        </button>
      </form>
    <% } %>
  </div>
</div>
